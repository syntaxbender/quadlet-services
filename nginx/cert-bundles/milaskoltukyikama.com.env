# Grouped SAN certificate example for example2.com
CERT_NAME=milaskoltukyikama.com
CERT_EMAIL=info@milaskoltukyikama.com
DOMAINS=milaskoltukyikama.com bodrum.milaskoltukyikama.com www.milaskoltukyikama.com
# Optional override per bundle. If empty, ACME_CHALLENGE_ROOT from rollout config is used.
# WEBROOT=/var/www/certbot
